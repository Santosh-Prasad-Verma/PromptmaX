# ── Django Core ──────────────────────────────────
DJANGO_SECRET_KEY=your-django-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
PORT=8000

# ── Database ─────────────────────────────────────
# SQLite (default, no config needed)
# PostgreSQL: DATABASE_URL=postgres://user:pass@host:5432/promptx
DATABASE_URL=

# ── Redis (optional, falls back to in-memory) ───
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# ── CORS ─────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# ── AI Models (NVIDIA) ───────────────────────────
NVIDIA_API_KEY=your-nvidia-api-key

# ── Google OAuth2 ────────────────────────────────
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=

# ── Email (SMTP) ─────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-smtp-app-password
DEFAULT_FROM_EMAIL=PromptmaX <your-email@example.com>
SERVER_EMAIL=PromptmaX <your-email@example.com>
EMAIL_TIMEOUT=15

# Razorpay checkout for paid PromptmaX plans
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_CURRENCY=INR

# ── Optional Client API Key ──────────────────────
CLIENT_API_KEY=

# ── Feature Flags ────────────────────────────────
ENABLE_FACT_CHECK=true
ENABLE_URL_VALIDATION=false
CHECK_URL_VALIDITY=false

# ── Performance ──────────────────────────────────
AI_REQUEST_TIMEOUT=30
AI_RETRY_COUNT=1
SCRAPER_MAX_PAGES=8
SCRAPER_CHARS_PER_PAGE=6000
SCRAPER_TIMEOUT=12

# ── Monitoring ───────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=INFO
