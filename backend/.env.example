# ── Django Core ──────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
PORT=8000

# ── Database ─────────────────────────────────────
# SQLite (default, no config needed)
# PostgreSQL: DATABASE_URL=postgres://user:pass@host:5432/promptx
DATABASE_URL=

# ── Redis (optional, falls back to in-memory) ───
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# ── CORS ─────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# ── AI Models (NVIDIA) ───────────────────────────
NVIDIA_API_KEY=your-nvidia-api-key

# ── Google OAuth2 ────────────────────────────────
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=

# ── Email (Resend) ───────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here

# ── Optional Client API Key ──────────────────────
CLIENT_API_KEY=

# ── Feature Flags ────────────────────────────────
ENABLE_FACT_CHECK=true
ENABLE_URL_VALIDATION=false
CHECK_URL_VALIDITY=false

# ── Performance ──────────────────────────────────
AI_REQUEST_TIMEOUT=30
AI_RETRY_COUNT=1
SCRAPER_MAX_PAGES=8
SCRAPER_CHARS_PER_PAGE=6000
SCRAPER_TIMEOUT=12

# ── Monitoring ───────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=INFO
