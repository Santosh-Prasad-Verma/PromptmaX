# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                         🔐 PROMPTX ENVIRONMENT CONFIG                        ║
# ║                    ── Copy this file to .env and configure ──                ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                        🛡️  DJANGO CORE SETTINGS                              ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

DJANGO_SECRET_KEY=your-django-secret-key
DEBUG=True


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                        🗄️  DATABASE CONFIGURATION                            ║
# ║                    ── PostgreSQL (Production Recommended) ──                 ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

DB_NAME=promptx
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                     🤖  AI MODEL API KEYS (Optional)                         ║
# ║            ── Add keys to enable automatic failover chain ──                 ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Google Gemini Models ─────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── GPT4Free (Free Models — no API key needed) ────────────────────────────
ENABLE_G4F=true

# SMTP mail sender for register, verification code, and password reset emails
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-smtp-app-password
DEFAULT_FROM_EMAIL=PromptmaX <your-email@example.com>
SERVER_EMAIL=PromptmaX <your-email@example.com>
EMAIL_TIMEOUT=15

# Razorpay checkout for paid PromptmaX plans
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_CURRENCY=INR


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                        ⚡  SERVER CONFIGURATION                              ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

PORT=5000


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                     💾  REDIS CACHING                                        ║
# ║              ── Enables high-performance caching layer ──                    ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

REDIS_URL=redis://localhost:6379/0


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                          🔐  SECURITY OPTIONS                                ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# CLIENT_API_KEY=your-optional-api-protection-key


# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                    📋  QUICK START CHECKLIST                                 ║
# ║  [ ] Copy this file:  cp .env.example .env                                   ║
# ║  [ ] Set DJANGO_SECRET_KEY to a random string                                ║
# ║  [ ] Add at least one AI API key (OpenAI/Gemini/NVIDIA/HF)                   ║
# ║  [ ] Configure database (PostgreSQL or keep SQLite default)                  ║
# ║  [ ] Run: python manage.py migrate                                           ║
# ╚══════════════════════════════════════════════════════════════════════════════╝
